{
  "name": "@file-reader/viewer",
  "version": "1.0.0",
  "description": "Edoc Viewer — secure encrypted document viewer",
  "productName": "Edoc Viewer",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && node scripts/copy-renderer.js && node scripts/bundle-renderer.js",
    "start": "npm run build -w @file-reader/server && npm run build && electron . 2>&1",
    "open": "electron .",
    "dev": "npm run build && electron ."
  },
  "dependencies": {
    "@file-reader/server": "*",
    "@file-reader/shared": "*",
    "pdfjs-dist": "^4.2.67"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "electron": "^30.0.2",
    "esbuild": "^0.21.3",
    "typescript": "^5.4.5"
  }
}
